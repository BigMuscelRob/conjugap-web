generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Verb {
  id           Int           @id @default(autoincrement())
  infinitive   String        @unique
  cls          String        // -ar, -er, -ir, irregulares
  irregular    Boolean       @default(false)
  meaningDe    String
  meaningEn    String
  conjugations Conjugation[]
}

model Conjugation {
  id      Int    @id @default(autoincrement())
  verbId  Int
  tense   String
  pronoun String
  form    String
  verb    Verb   @relation(fields: [verbId], references: [id])

  @@unique([verbId, tense, pronoun])
}
