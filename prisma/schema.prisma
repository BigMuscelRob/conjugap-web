generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Verb {
  id           Int           @id @default(autoincrement())
  infinitive   String        @unique
  cls          String        // -ar, -er, -ir, irregulares
  irregular    Boolean       @default(false)
  meaningDe    String
  meaningEn    String
  conjugations Conjugation[]
}

model Conjugation {
  id       Int            @id @default(autoincrement())
  verbId   Int
  tense    String
  pronoun  String
  form     String
  verb     Verb           @relation(fields: [verbId], references: [id])
  progress UserProgress[]

  @@unique([verbId, tense, pronoun])
}

// ── Auth.js (NextAuth v5) ─────────────────────────────────────────────────────

model User {
  id                 String            @id @default(cuid())
  name               String?
  email              String?           @unique
  emailVerified      DateTime?
  image              String?
  accounts           Account[]
  sessions           Session[]
  createdAt          DateTime          @default(now())
  currentStreak      Int               @default(0)
  longestStreak      Int               @default(0)
  lastPracticeDate   DateTime?
  progress           UserProgress[]
  practiceSessions   PracticeSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Progress Tracking ─────────────────────────────────────────────────────────

model UserProgress {
  id            String      @id @default(cuid())
  userId        String
  conjugationId Int
  correct       Int         @default(0)
  incorrect     Int         @default(0)
  lastPracticed DateTime?
  easeFactor    Float?
  nextReview    DateTime?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  conjugation   Conjugation @relation(fields: [conjugationId], references: [id])

  @@unique([userId, conjugationId])
}

model PracticeSession {
  id               String    @id @default(cuid())
  userId           String
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  mode             String
  tenses           String[]
  verbIds          Int[]
  totalQuestions   Int
  correctCount     Int       @default(0)
  incorrectCount   Int       @default(0)
  durationSeconds  Int?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
